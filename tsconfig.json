{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext","DOM"],
    "target": "ES2020",
    "module": "ESNext",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "jsxImportSource": "auwla",
    "allowJs": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "auwla": ["src/index.ts"],
      "auwla/jsx-runtime": ["src/jsx-runtime.ts"],
      "auwla/jsx-dev-runtime": ["src/jsx-dev-runtime.ts"],
      "auwla/compiler": ["src/compiler.ts"],
      "auwla/events": ["src/events/index.ts"],
      "auwla/router": ["src/router/index.ts"],
      "auwla/css": ["src/css/index.ts"]
    },

    // Bundler mode
    "moduleResolution": "node",
    "esModuleInterop": true,

    // Declaration files
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "outDir": "./dist",

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    // "noPropertyAccessFromIndexSignature": false
  },
  "include": ["src/**/*", "examples/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "benchmark"]
}
