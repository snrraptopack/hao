{
  "name": "auwla",
  "version": "0.3.32",
  "description": "A tiny typed DOM runtime with event-driven rerendering and memoized DOM reuse",
  "type": "module",
  "main": "./dist/auwla.js",
  "module": "./dist/auwla.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/auwla.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime.d.ts",
      "import": "./dist/jsx-dev-runtime.js"
    },
    "./compiler": {
      "types": "./dist/compiler.d.ts",
      "import": "./dist/compiler.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "import": "./dist/events/index.js"
    },
    "./events/intersect": {
      "types": "./dist/events/intersect.d.ts",
      "import": "./dist/events/intersect.js"
    },
    "./events/touch": {
      "types": "./dist/events/touch.d.ts",
      "import": "./dist/events/touch.js"
    },
    "./events/keyboard": {
      "types": "./dist/events/keyboard.d.ts",
      "import": "./dist/events/keyboard.js"
    },
    "./events/hotkey": {
      "types": "./dist/events/hotkey.d.ts",
      "import": "./dist/events/hotkey.js"
    },
    "./css": {
      "types": "./dist/css/index.d.ts",
      "import": "./dist/css/index.js"
    },
    "./track": {
      "types": "./dist/track/index.d.ts",
      "import": "./dist/track/index.js"
    },
    "./router": {
      "types": "./dist/router/index.d.ts",
      "import": "./dist/router/index.js"
    },
    "./vite-router": {
      "types": "./dist/vite-router/index.d.ts",
      "import": "./dist/vite-router/index.js"
    },
    "./vite-router/client": {
      "types": "./dist/vite-router/client.d.ts"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./runtime/ssr": {
      "types": "./dist/runtime/ssr.d.ts",
      "import": "./dist/runtime/ssr.js"
    },
    "./runtime/app": {
      "types": "./dist/runtime/app.d.ts",
      "import": "./dist/runtime/app.js"
    },
    "./runtime/islands": {
      "types": "./dist/runtime/islands.d.ts",
      "import": "./dist/runtime/islands.js"
    },
    "./runtime/static": {
      "types": "./dist/runtime/static.d.ts",
      "import": "./dist/runtime/static.js"
    },
    "./client": {
      "types": "./dist/client/rpc.d.ts",
      "import": "./dist/client/rpc.js"
    },
    "./adapters/fetch": {
      "types": "./dist/adapters/fetch.d.ts",
      "import": "./dist/adapters/fetch.js"
    },
    "./adapters/hono": {
      "types": "./dist/adapters/hono.d.ts",
      "import": "./dist/adapters/hono.js"
    },
    "./adapters/bun": {
      "types": "./dist/adapters/bun.d.ts",
      "import": "./dist/adapters/bun.js"
    },
    "./adapters/express": {
      "types": "./dist/adapters/express.d.ts",
      "import": "./dist/adapters/express.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "ui",
    "dom",
    "jsx",
    "typescript",
    "lightweight"
  ],
  "author": "snrraptopack",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/snrraptopack/auwla.git"
  },
  "homepage": "https://github.com/snrraptopack/auwla#readme",
  "bugs": {
    "url": "https://github.com/snrraptopack/auwla/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --project tsconfig.lib.json && node -e \"import('node:fs').then(fs => fs.copyFileSync('src/vite-router/client.d.ts', 'dist/vite-router/client.d.ts'))\" && bun run scratch/sync_site.ts",
    "preview": "vite preview",
    "prepublishOnly": "bun run build",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^24.1.3",
    "playwright": "^1.61.1",
    "typescript": "^5.9.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {}
}
