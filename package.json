{
  "name": "auwla",
  "version": "0.3.2",
  "description": "A tiny typed DOM runtime with event-driven rerendering and memoized DOM reuse",
  "type": "module",
  "main": "./dist/auwla.js",
  "module": "./dist/auwla.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/auwla.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime.d.ts",
      "import": "./dist/jsx-dev-runtime.js"
    },
    "./compiler": {
      "types": "./dist/compiler.d.ts",
      "import": "./dist/compiler.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "import": "./dist/events/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "jsx-runtime": [
        "dist/jsx-runtime.d.ts"
      ],
      "jsx-dev-runtime": [
        "dist/jsx-dev-runtime.d.ts"
      ],
      "compiler": [
        "dist/compiler.d.ts"
      ],
      "vite": [
        "dist/vite.d.ts"
      ],
      "events": [
        "dist/events/index.d.ts"
      ],
      "*": [
        "dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "ui",
    "dom",
    "jsx",
    "typescript",
    "lightweight"
  ],
  "author": "snrraptopack",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/snrraptopack/auwla.git"
  },
  "homepage": "https://github.com/snrraptopack/auwla#readme",
  "bugs": {
    "url": "https://github.com/snrraptopack/auwla/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --project tsconfig.lib.json --emitDeclarationOnly --declaration --outDir dist",
    "preview": "vite preview",
    "prepublishOnly": "bun run build",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@vitest/coverage-v8": "^1.6.1",
    "jsdom": "^24.1.3",
    "typescript": "^5.9.3",
    "vite": "^7.0.0",
    "vitest": "^1.6.1"
  }
}
